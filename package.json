{
  "type": "module",
  "name": "km-test",
  "version": "0.1.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 1420 --proxy-config proxy.conf.js",
    "build": "pnpm run generate:build-info && ng build",
    "watch": "ng build --watch --configuration development",
    "tauri": "tauri",
    "generate:build-info": "node scripts/generate-build-info.mjs",
    "release": "node scripts/bump-version.mjs",
    "release:patch": "node scripts/bump-version.mjs patch",
    "release:minor": "node scripts/bump-version.mjs minor",
    "release:major": "node scripts/bump-version.mjs major",
    "ship:patch": "node scripts/bump-version.mjs patch --push",
    "ship:minor": "node scripts/bump-version.mjs minor --push",
    "ship:major": "node scripts/bump-version.mjs major --push",
    "lint": "eslint src --ext .ts,.html",
    "lint:fix": "eslint src --ext .ts,.html --fix",
    "jscpd": "jscpd src --reporters console --min-tokens 50 --ignore node_modules/** --ignore src-tauri/target/**",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "e2e:report": "playwright show-report dist/e2e-report",
    "verify": "pnpm run build && pnpm run lint && pnpm run jscpd"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@isomorphic-git/lightning-fs": "^4.6.2",
    "@lucide/angular": "^1.14.0",
    "@milkdown/crepe": "^7.21.1",
    "@milkdown/kit": "^7.21.1",
    "@taiga-ui/addon-mobile": "^5.5.0",
    "@taiga-ui/addon-table": "^5.5.0",
    "@taiga-ui/cdk": "^5.5.0",
    "@taiga-ui/core": "^5.5.0",
    "@taiga-ui/icons": "^5.5.0",
    "@taiga-ui/kit": "^5.5.0",
    "@taiga-ui/polymorpheus": "^5.0.0",
    "@taiga-ui/styles": "^5.5.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2",
    "buffer": "^6.0.3",
    "isomorphic-git": "^1.38.4",
    "postcss": "^8.5.14",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tauri-apps/cli": "^2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-plugin-import": "^2.32.0",
    "fake-indexeddb": "^6.2.5",
    "jscpd": "^4.2.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
