{
  "type": "module",
  "name": "km-test",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 1420",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "tauri": "tauri",
    "lint": "eslint src --ext .ts,.html",
    "lint:fix": "eslint src --ext .ts,.html --fix",
    "jscpd": "jscpd src --reporters console --min-tokens 50 --ignore node_modules/** --ignore src-tauri/target/**",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "e2e:report": "playwright show-report dist/e2e-report",
    "verify": "pnpm run build && pnpm run lint && pnpm run jscpd"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@lucide/angular": "^1.14.0",
    "@taiga-ui/addon-mobile": "^5.5.0",
    "@taiga-ui/addon-table": "^5.5.0",
    "@taiga-ui/cdk": "^5.5.0",
    "@taiga-ui/core": "^5.5.0",
    "@taiga-ui/icons": "^5.5.0",
    "@taiga-ui/kit": "^5.5.0",
    "@taiga-ui/polymorpheus": "^5.0.0",
    "@taiga-ui/styles": "^5.5.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/core": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "ngx-tiptap": "^14.0.1",
    "postcss": "^8.5.14",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.10",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tauri-apps/cli": "^2",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-plugin-import": "^2.32.0",
    "jasmine-core": "~5.1.0",
    "jscpd": "^4.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}