{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dotta",
  "version": "../package.json",
  "identifier": "space.dotta.app",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/dotta/browser"
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": [
            "com.googleusercontent.apps.311145204704-q253fucp3v6fnintq3c285kkvhrqqg5c"
          ]
        }
      ]
    }
  },
  "app": {
    "windows": [
      {
        "title": "dotta",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}